{
  "name": "db-engineering-challenge",
  "version": "1.0.0",
  "description": "An integration service that fetches data from GitHub and NASA NeoWs APIs and pushes it to Databox via the v1 Ingestion API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env --clear-screen=false src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luka-DV/db-engineering-challenge.git"
  },
  "keywords": [],
  "author": "Luka-DV",
  "license": "MIT",
  "type": "module", 
  "engines": {
    "node": ">=20.6.0"
  },
  "bugs": {
    "url": "https://github.com/Luka-DV/db-engineering-challenge/issues"
  },
  "homepage": "https://github.com/Luka-DV/db-engineering-challenge#readme",
  "dependencies": {
    "axios": "^1.15.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
